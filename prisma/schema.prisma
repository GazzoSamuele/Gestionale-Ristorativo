generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tavolo {
  id                   String @id @default(cuid())
  numero               Int    @unique
  capienza             Int
  posX                 Float
  posY                 Float
  prenotazioni         Prenotazione[]
  occupazioni          Occupazione[]
}

enum StatoPrenotazione {
  IN_ATTESA
  ANNULLATA
  NON_PRESENTATA
}

model Prenotazione {
  id                   String  @id @default(cuid())
  nome                 String
  telefono             String?
  copertiPrenotati     Int
  dataOra              DateTime
  note                 String?
  stato                StatoPrenotazione  @default(IN_ATTESA) 
  tavolo               Tavolo? @relation(fields: [tavoloId], references: [id])
  tavoloId             String? 
  occupazioni          Occupazione?
}

model Occupazione {
  id                   String       @id @default(cuid())
  tavolo               Tavolo @relation(fields: [tavoloId], references: [id], onDelete: Restrict)
  tavoloId             String
  prenotazione         Prenotazione? @relation(fields: [prenotazioneId], references: [id])
  prenotazioneId       String? @unique
  copertiPresenti      Int
  iniziataAlle         DateTime     @default(now())
  terminataAlle        DateTime?
  oraPagamento         DateTime?
}

model Piatto {
  id                   String  @id @default(cuid())
  nome                 String
  prezzo               Decimal @db.Decimal(10, 2)
  disponibile          Boolean @default(true)
  categoria            Categoria @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  categoriaId          String
}

model Categoria {
  id                  String     @id @default(cuid())
  nome                String
  ordine              Int
  piatti              Piatto[] 
}