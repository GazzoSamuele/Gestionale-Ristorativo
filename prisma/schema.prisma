generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tavolo {
  id                   String @id @default(cuid())
  numero               Int    @unique
  capienza             Int
  posX                 Float
  posY                 Float
  prenotazioni         Prenotazione[]
  occupazioni          Occupazione[]
}

enum StatoPrenotazione {
  IN_ATTESA
  ANNULLATA
  NON_PRESENTATA
}

model Prenotazione {
  id                   String  @id @default(cuid())
  nome                 String
  telefono             String?
  copertiPrenotati     Int
  dataOra              DateTime
  note                 String?
  stato                StatoPrenotazione  @default(IN_ATTESA) 
  tavolo               Tavolo? @relation(fields: [tavoloId], references: [id])
  tavoloId             String? 
  occupazioni          Occupazione?
}

model Occupazione {
  id                   String       @id @default(cuid())
  tavolo               Tavolo @relation(fields: [tavoloId], references: [id], onDelete: Restrict)
  tavoloId             String
  prenotazione         Prenotazione? @relation(fields: [prenotazioneId], references: [id])
  prenotazioneId       String? @unique
  copertiPresenti      Int
  iniziataAlle         DateTime     @default(now())
  terminataAlle        DateTime?
  oraPagamento         DateTime?
  ordini               Ordine[]
}

model Piatto {
  id                   String  @id @default(cuid())
  nome                 String
  prezzo               Decimal @db.Decimal(10, 2)
  disponibile          Boolean @default(true)
  categoria            Categoria @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  categoriaId          String
  righe                RigaOrdine[]
}

model Categoria {
  id                  String     @id @default(cuid())
  nome                String
  ordine              Int
  piatti              Piatto[] 
}

enum FonteOrdine {
  SALA
  ASPORTO
}

enum StatoOrdine {
  NUOVI_ARRIVATI
  IN_CORSO
  PRONTI
}

model Ordine {
  id                   String  @id @default(cuid())
  numero               Int  @default(autoincrement()) @unique
  fonte                FonteOrdine  
  stato                StatoOrdine @default(NUOVI_ARRIVATI)
  creatoIl             DateTime @default(now())
  statoDalle           DateTime @default(now())
  nomeCliente          String?
  occupazione          Occupazione? @relation(fields: [occupazioneId], references: [id])
  occupazioneId        String?
  righe                RigaOrdine[]
  creatoDa             Utente? @relation(fields: [creatoDaId], references: [id])
  creatoDaId           String?
}

model RigaOrdine {
  id                  String @id @default(cuid())
  piatto              Piatto @relation(fields: [piattoId], references: [id], onDelete: Restrict)
  piattoId            String
  ordine              Ordine @relation(fields: [ordineId], references: [id], onDelete: Cascade)
  ordineId            String
  quantita            Int @default(1)
  prezzoUnitario      Decimal @db.Decimal(10,2)
  note                String?
}

enum RuoloUtente {
  OPERATORE
  ADMIN
  SUPER_ADMIN
}

model Utente {
  id                  String     @id @default(cuid())
  nome                String
  ruolo               RuoloUtente @default(OPERATORE)
  ordini         Ordine[]
}